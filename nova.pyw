        def _get_ordered_awg_profiles(self):
            profiles = []
            for source_name, source_dir in (
                ("user", self.awg_profiles_dir),
                ("builtin", self.awg_builtin_profiles_dir),
            ):
                try:
                    os.makedirs(source_dir, exist_ok=True)
                    for entry in sorted(os.listdir(source_dir), key=lambda x: x.lower()):
                        path = os.path.join(source_dir, entry)
                        if not os.path.isfile(path):
                            continue
                        if not str(entry).lower().endswith(".conf"):
                            continue
                        if not self._is_awg_profile_candidate(path):
                            continue
                        profiles.append({
                            "name": os.path.splitext(os.path.basename(path))[0],
                            "path": path,
                            "source": source_name,
                        })
                except:
                    continue

            preferred = self._load_preferred_awg_profile_name().lower()
            rank_map = self._load_awg_profile_rank_map()
            profiles.sort(
                key=lambda p: (
                    0 if str(p.get("source", "user")).lower() == "user" else 1,
                    0 if str(p.get("name", "")).lower() == preferred else 1,
                    rank_map.get(str(p.get("name", "")).lower(), 10**9),
                    str(p.get("name", "")).lower(),
                )
            )
            return profiles

        def _build_awg_runtime_config_path(self, profile_name):
            try:
                import re
                safe_name = re.sub(r"[^A-Za-z0-9._-]+", "_", str(profile_name or "awg"))
            except:
                safe_name = "awg"
            return os.path.join(self.awg_runtime_dir, f"{safe_name}.conf")

        def _parse_awg_source_profile(self, profile_path):
            parsed = {
                "interface": {},
                "peer": {},
                "awg_lines": [],
            }
            try:
                import re
                current_section = ""
                with open(profile_path, "r", encoding="utf-8", errors="ignore") as f:
                    for raw_line in f:
                        line = str(raw_line).rstrip("\r\n")
                        stripped = line.strip()
                        if not stripped or stripped.startswith("#") or stripped.startswith(";"):
                            continue
                        if stripped.startswith("[") and stripped.endswith("]"):
                            current_section = stripped[1:-1].strip().lower()
                            continue
                        if "=" not in stripped:
                            continue
                        key, value = stripped.split("=", 1)
                        key = key.strip()
                        value = value.strip()
                        key_low = key.lower()
                        if current_section == "interface":
                            parsed["interface"][key_low] = value
                            if re.match(r"(?i)^(jc|jmin|jmax|s[1-4]|h[1-4]|i[1-5])$", key):
                                parsed["awg_lines"].append(f"{key} = {value}")
                        elif current_section == "peer":
                            parsed["peer"][key_low] = value
            except:
                pass
            return parsed

        def _load_cached_awg_native_profile(self):
            try:
                path = os.path.join(self.temp_dir, "warp-native-profile.json")
                if not os.path.exists(path):
                    return None
                with open(path, "r", encoding="utf-8") as f:
                    data = json.load(f)
                if not isinstance(data, dict):
                    return None
                required = ["private_key", "peer_public_key", "local_addresses"]
                if any(not data.get(k) for k in required):
                    return None
                return data
            except:
                return None

        def _get_personal_awg_identity(self):
            cached = self._load_cached_awg_native_profile()
            if cached:
                return cached
            return None

        def _is_awg_cloudflare_profile(self, profile, parsed=None):
            try:
                name_low = str(profile.get("name", "") or "").strip().lower()
                if "warp" in name_low or name_low.startswith("str.warp"):
                    return True
                if parsed is None:
                    parsed = self._parse_awg_source_profile(str(profile.get("path", "") or ""))
                endpoint = str((parsed.get("peer") or {}).get("endpoint", "") or "").strip().lower()
                return (
                    "cloudflare" in endpoint or
                    "162.159." in endpoint or
                    "188.114." in endpoint
                )
            except:
                return False

        def _render_awg_runtime_payload(self, profile, allow_personal_identity=True):
            profile_path = str(profile.get("path", "") or "").strip()
            if not profile_path or not os.path.exists(profile_path):
                return "", False

            parsed = self._parse_awg_source_profile(profile_path)
            iface = parsed.get("interface") or {}
            peer = parsed.get("peer") or {}

            private_key = str(iface.get("privatekey", "") or "").strip()
            addresses_raw = str(iface.get("address", "") or "").strip()
            peer_public_key = str(peer.get("publickey", "") or "").strip()
            endpoint = str(peer.get("endpoint", "") or "").strip()
            allowed_ips = str(peer.get("allowedips", "0.0.0.0/0, ::/0") or "0.0.0.0/0, ::/0").strip()
            dns_value = str(iface.get("dns", "1.1.1.1, 1.0.0.1") or "1.1.1.1, 1.0.0.1").strip()
            mtu_value = str(iface.get("mtu", "1280") or "1280").strip()
            preshared_key = str(peer.get("presharedkey", "") or "").strip()
            keepalive = str(peer.get("persistentkeepalive", "25") or "25").strip()

            using_personal_identity = False
            if allow_personal_identity and self._is_awg_cloudflare_profile(profile, parsed=parsed):
                native = self._get_personal_awg_identity()
                if isinstance(native, dict):
                    native_priv = str(native.get("private_key", "") or "").strip()
                    native_peer_pub = str(native.get("peer_public_key", "") or "").strip()
                    native_addrs = [str(x).strip() for x in (native.get("local_addresses") or []) if str(x).strip()]
                    if native_priv and native_peer_pub and native_addrs:
                        private_key = native_priv
                        peer_public_key = native_peer_pub
                        addresses_raw = ", ".join(native_addrs)
                        using_personal_identity = True

            if not private_key or not addresses_raw or not peer_public_key or not endpoint:
                return "", using_personal_identity

            lines = [
                "[Interface]",
                f"PrivateKey = {private_key}",
                f"Address = {addresses_raw}",
            ]
            if dns_value:
                lines.append(f"DNS = {dns_value}")
            if mtu_value:
                lines.append(f"MTU = {mtu_value}")
            for awg_line in (parsed.get("awg_lines") or []):
                if awg_line:
                    lines.append(awg_line)

            lines.extend([
                "",
                "[Peer]",
                f"PublicKey = {peer_public_key}",
            ])
            if preshared_key:
                lines.append(f"PresharedKey = {preshared_key}")
            lines.extend([
                f"AllowedIPs = {allowed_ips}",
                f"Endpoint = {endpoint}",
            ])
            if keepalive:
                lines.append(f"PersistentKeepalive = {keepalive}")

            lines.extend([
                "",
                "[Socks5]",
                f"BindAddress = 127.0.0.1:{int(self.port)}",
                "",
            ])
            return "\n".join(lines), using_personal_identity

        def _write_awg_runtime_config(self, profile, allow_personal_identity=True):
            profile_path = str(profile.get("path", "") or "").strip()
            if not profile_path or not os.path.exists(profile_path):
                return ""
            os.makedirs(self.awg_runtime_dir, exist_ok=True)
            cfg_path = self._build_awg_runtime_config_path(profile.get("name", "awg"))
            payload, using_personal_identity = self._render_awg_runtime_payload(
                profile,
                allow_personal_identity=allow_personal_identity,
            )
            if not payload:
                return ""
            with open(cfg_path, "w", encoding="utf-8", newline="\n") as f:
                f.write(payload)
            self.awg_runtime_config_path = cfg_path
            try:
                profile["using_personal_identity"] = bool(using_personal_identity)
            except:
                pass
            return cfg_path

        def _read_awg_log_tail(self, lines=6):
            try:
                if not os.path.exists(self.awg_log_path):
                    return []
                with open(self.awg_log_path, "r", encoding="utf-8", errors="ignore") as f:
                    content = f.readlines()
                return [str(x).rstrip() for x in content[-max(1, int(lines)):]]
            except:
                return []

        def _kill_awg_proxy_orphans(self):
            try:
                subprocess.run(
                    ["taskkill", "/F", "/IM", "wireproxy-awg.exe", "/T"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    creationflags=subprocess.CREATE_NO_WINDOW,
                    timeout=4,
                )
            except:
                pass

        def _wait_local_port_closed(self, port, timeout=3.0):
            deadline = time.time() + max(0.5, float(timeout))
            while time.time() < deadline:
                try:
                    if not self.is_port_open(int(port)):
                        return True
                except:
                    return True
                time.sleep(0.15)
            return False

        def _stop_awg_proxy_process(self, reset_backend=True, force_orphans=False):
            try:
                proc = getattr(self, "awg_process", None)
                if proc:
                    try:
                        if proc.poll() is None:
                            proc.terminate()
                            try:
                                proc.wait(timeout=4)
                            except:
                                proc.kill()
                                proc.wait(timeout=3)
                    except:
                        pass
            except:
                pass
            if force_orphans:
                self._kill_awg_proxy_orphans()
                try:
                    self._wait_local_port_closed(self.port, timeout=3.0)
                except:
                    pass
            try:
                if getattr(self, "awg_log_handle", None):
                    try:
                        self.awg_log_handle.flush()
                    except:
                        pass
                    try:
                        self.awg_log_handle.close()
                    except:
                        pass
            except:
                pass
            self.awg_process = None
            self.awg_log_handle = None
            if reset_backend:
                if self.active_backend == "awg":
                    self.active_backend = "cloudflare"
                self.awg_active_profile_name = ""
                self.awg_runtime_config_path = ""
                if self.active_backend != "awg":
                    self.is_connected = False

        def _test_awg_backend_ready(self, port=None, timeout=8.0):
            try:
                use_port = int(port or self.port)
                if not self.is_port_open(use_port):
                    return False
                curl_cmd = [
                    "curl.exe",
                    "--socks5-hostname", f"127.0.0.1:{use_port}",
                    "--max-time", str(max(4, int(timeout))),
                    "--silent",
                    "--show-error",
                    "https://cloudflare.com/cdn-cgi/trace",
                ]
                result = subprocess.run(
                    curl_cmd,
                    capture_output=True,
                    text=True,
                    encoding="utf-8",
                    errors="replace",
                    creationflags=subprocess.CREATE_NO_WINDOW,
                    timeout=max(6, int(timeout) + 4),
                )
                text = f"{result.stdout or ''}\n{result.stderr or ''}"
                return result.returncode == 0 and ("ip=" in text or "warp=" in text)
            except:
                return False

        def _is_awg_backend_healthy(self, timeout=2.0):
            try:
                return bool(self._test_awg_backend_ready(self.port, timeout=timeout))
            except:
                return False

        def _start_awg_proxy_backend(self, profile, allow_personal_identity=True):
            try:
                if not os.path.exists(self.wireproxy_awg_path):
                    return False

                cfg_path = self._write_awg_runtime_config(
                    profile,
                    allow_personal_identity=allow_personal_identity,
                )
                if not cfg_path:
                    return False

                self._stop_awg_proxy_process(reset_backend=False)

                try:
                    self.run_warp_cli("disconnect", timeout=4)
                except:
                    pass
                try:
                    self._run_sc("stop", self.SERVICE_NAME, timeout=8)
                except:
                    pass
                time.sleep(0.5)

                existing_deadline = time.time() + 2.5
                while time.time() < existing_deadline:
                    if self._is_awg_backend_healthy(timeout=1.5):
                        self.awg_active_profile_name = str(profile.get("name", "") or "").strip()
                        self.active_backend = "awg"
                        self.last_bootstrap_transport = "awg_proxy"
                        self.is_connected = True
                        self.mark_bootstrap(True)
                        self._remember_successful_awg_profile(self.awg_active_profile_name)
                        self.log_func(f"[RU] [Diag] AWG backend уже активен на порту {self.port}. Используем текущий экземпляр.")
                        return True
                    if not self.is_port_open(self.port):
                        break
                    time.sleep(0.25)

                if self.is_port_open(self.port):
                    self.log_func(f"[RU] [AWG] Порт {self.port} занят нерабочим wireproxy. Очищаем старый экземпляр...")
                    self._kill_awg_proxy_orphans()
                    self._wait_local_port_closed(self.port, timeout=4.0)
                    if self.is_port_open(self.port):
                        self.log_func(f"[RU] [AWG] Порт {self.port} всё ещё занят. Пропускаем профиль {profile.get('name', 'awg')}.")
                        self._stop_awg_proxy_process(reset_backend=True, force_orphans=True)
                        return False

                os.makedirs(self.temp_dir, exist_ok=True)
                self.awg_log_handle = open(self.awg_log_path, "w", encoding="utf-8", errors="ignore")
                cmd = [
                    self.wireproxy_awg_path,
                    "-c", cfg_path,
                    "-i", "127.0.0.1:1396",
                ]
                try:
                    cmd_dump_path = os.path.join(get_base_dir(), "temp", "awg_last_command.txt")
                    with open(cmd_dump_path, "w", encoding="utf-8") as dump_f:
                        dump_f.write(subprocess.list2cmdline(cmd))
                except:
                    pass

                self.awg_process = subprocess.Popen(
                    cmd,
                    cwd=get_base_dir(),
                    stdout=self.awg_log_handle,
                    stderr=self.awg_log_handle,
                    stdin=subprocess.DEVNULL,
                    creationflags=subprocess.CREATE_NO_WINDOW,
                )
                self.awg_active_profile_name = str(profile.get("name", "") or "").strip()
                self.active_backend = "awg"
                self.last_bootstrap_transport = "awg_proxy"
                if profile.get("using_personal_identity"):
                    self.log_func(f"[RU] [Diag] AWG использует личный Cloudflare профиль поверх {self.awg_active_profile_name}.")
                else:
                    self.log_func(f"[RU] [Diag] AWG использует встроенные ключи профиля {self.awg_active_profile_name}.")

                # Personal Cloudflare identity is worth trying first, but it must
                # fail fast enough to not hold Telegram bootstrap hostage when the
                # profile's built-in keys would connect immediately afterwards.
                using_personal_identity = bool(profile.get("using_personal_identity"))
                startup_deadline_sec = 2.0 if using_personal_identity and allow_personal_identity else 10.0
                deadline = time.time() + startup_deadline_sec
                while time.time() < deadline:
                    if is_closing:
                        break
                    if self.awg_process and self.awg_process.poll() is not None:
                        break
                    if self._test_awg_backend_ready(self.port, timeout=0.5):
                        self.is_connected = True
                        self.mark_bootstrap(True)
                        self._remember_successful_awg_profile(self.awg_active_profile_name)
                        return True
                    time.sleep(0.5)

                if IS_DEBUG_MODE:
                    for line in self._read_awg_log_tail(lines=5):
                        if line:
                            self.log_func(f"[RU] [AWG] {line}")
            except Exception as e:
                if IS_DEBUG_MODE:
                    self.log_func(f"[RU] [AWG] Ошибка запуска профиля {profile.get('name', 'awg')}: {e}")

            used_personal_identity = bool(profile.get("using_personal_identity"))
            self._stop_awg_proxy_process(reset_backend=True, force_orphans=True)
            if allow_personal_identity and used_personal_identity and not is_closing:
                self.log_func(f"[RU] [AWG] Личный Cloudflare профиль не прошёл handshake для {profile.get('name', 'awg')}. Пробуем встроенные ключи.")
                return self._start_awg_proxy_backend(profile, allow_personal_identity=False)
            return False

        def _try_start_awg_profiles(self, my_run_id, preferred_only=False):
            profiles = self._get_ordered_awg_profiles()
            if not profiles:
                return False
            if not os.path.exists(self.wireproxy_awg_path):
                self.log_func("[RU] [Diag] AWG backend пропущен: wireproxy-awg.exe не найден.")
                return False

            total = len(profiles)
            for idx, profile in enumerate(profiles, start=1):
                if is_closing or SERVICE_RUN_ID != my_run_id:
                    return False
                if preferred_only and idx > 1:
                    break
                profile_name = str(profile.get("name", f"awg-{idx}") or f"awg-{idx}")
                if total > 1:
                    self.log_func(f"[RU] [Diag] AWG профиль {idx}/{total}: {profile_name}.")
                else:
                    self.log_func(f"[RU] [Diag] AWG профиль: {profile_name}.")
                if self._start_awg_proxy_backend(profile):
                    self.log_func(f"[RU] [Diag] AWG профиль сработал: {profile_name}.")
                    return True
                time.sleep(0.4)
            return False

        def _recover_awg_backend(self, reason=""):
            if is_closing:
                return False
            reason_txt = str(reason or "").strip()
            if reason_txt:
                self.log_func(f"[RU] [AWG] Восстановление профиля: {reason_txt}.")
            if self._is_awg_backend_healthy(timeout=2.0):
                self.is_connected = True
                return True
            current_name = str(getattr(self, "awg_active_profile_name", "") or "").strip().lower()
            self._stop_awg_proxy_process(reset_backend=True, force_orphans=True)
            profiles = self._get_ordered_awg_profiles()
            if current_name:
                profiles.sort(key=lambda p: 0 if str(p.get("name", "")).strip().lower() == current_name else 1)
            for profile in profiles:
                if self._start_awg_proxy_backend(profile):
                    return True
            return False

        def _normalize_warp_port_specs(self, ports_raw):
            specs = []

            def _add(spec):
                spec = str(spec or "").strip()
                if not spec:
                    return
                if "-" in spec:
                    try:
                        start_s, end_s = spec.split("-", 1)
                        start_i = int(start_s)
                        end_i = int(end_s)
                        if start_i > end_i:
                            start_i, end_i = end_i, start_i
                        if 1 <= start_i <= 65535 and 1 <= end_i <= 65535:
                            norm = f"{start_i}-{end_i}"
                            if norm not in specs:
                                specs.append(norm)
                    except:
                        return
                else:
                    try:
                        port_i = int(spec)
                    except:
                        return
                    if 1 <= port_i <= 65535:
                        norm = str(port_i)
                        if norm not in specs:
                            specs.append(norm)

            if isinstance(ports_raw, str):
                for part in ports_raw.split(","):
                    _add(part)
            elif isinstance(ports_raw, (list, tuple, set)):
                for part in ports_raw:
                    _add(part)
            return specs

        def _collect_warp_port_specs_from_args(self, args_list):
            specs = []
            try:
                for arg in list(args_list or []):
                    if not isinstance(arg, str):
                        continue
                    arg = arg.strip()
                    if not arg:
                        continue
                    if arg.startswith("--filter-udp=") or arg.startswith("--wf-udp="):
                        part_specs = self._normalize_warp_port_specs(arg.split("=", 1)[1])
                        for spec in part_specs:
                            if spec not in specs:
                                specs.append(spec)
            except:
                pass
            return specs

        def _normalize_warp_protocols(self, raw_protocols):
            if isinstance(raw_protocols, str):
                raw_protocols = [raw_protocols]
            protocols = []
            for proto in list(raw_protocols or []):
                p = str(proto or "").strip().lower()
                if p == "masque":
                    norm = "MASQUE"
                elif p in ("wireguard", "warp", "wg"):
                    norm = "WireGuard"
                else:
                    continue
                if norm not in protocols:
                    protocols.append(norm)
            if not protocols:
                protocols = ["MASQUE", "WireGuard"]
            return protocols

        def _normalize_warp_masque_options(self, raw_options):
            if isinstance(raw_options, str):
                raw_options = [raw_options]
            options = []
            for opt in list(raw_options or []):
                o = str(opt or "").strip().lower()
                if o in ("h3-with-h2-fallback", "h2-only", "h3-only", "reset") and o not in options:
                    options.append(o)
            if not options:
                options = ["h3-with-h2-fallback"]
            return options

        def _normalize_warp_endpoints(self, raw_endpoints):
            seen = set()
            result = []
            if isinstance(raw_endpoints, str):
                raw_endpoints = [raw_endpoints]
            for item in list(raw_endpoints or []):
                host = ""
                port = None
                if isinstance(item, dict):
                    host = str(item.get("host", "") or "").strip()
                    port = item.get("port", None)
                else:
                    text = str(item or "").strip()
                    if not text:
                        continue
                    if text.startswith("[") and "]:" in text:
                        try:
                            host, port = text[1:].rsplit("]:", 1)
                        except:
                            host, port = "", None
                    elif ":" in text:
                        try:
                            host, port = text.rsplit(":", 1)
                        except:
                            host, port = "", None
                try:
                    port = int(port)
                except:
                    continue
                if not host or not (1 <= port <= 65535):
                    continue
                key = (host, int(port))
                if key in seen:
                    continue
                seen.add(key)
                result.append({"host": host, "port": int(port)})
            return result

        def _normalize_warp_bootstrap_profile(self, raw_profile, idx):
            try:
                if isinstance(raw_profile, list):
                    name = f"warp-{idx}"
                    args = list(raw_profile)
                    ports_raw = []
                    protocols = ["MASQUE", "WireGuard"]
                    masque_options = ["h3-with-h2-fallback"]
                    endpoints = []
                    prefer_exact_endpoints = False
                elif isinstance(raw_profile, dict):
                    name = str(raw_profile.get("name") or f"warp-{idx}").strip() or f"warp-{idx}"
                    args = raw_profile.get("args", [])
                    ports_raw = raw_profile.get("ports", [])
                    protocols = self._normalize_warp_protocols(raw_profile.get("protocols"))
                    masque_options = self._normalize_warp_masque_options(raw_profile.get("masque_options"))
                    endpoints = self._normalize_warp_endpoints(raw_profile.get("endpoints"))
                    prefer_exact_endpoints = bool(raw_profile.get("prefer_exact_endpoints", False))
                else:
                    return None

                if not isinstance(args, list):
                    return None
                args = [str(arg).strip() for arg in args if isinstance(arg, str) and str(arg).strip()]
                port_specs = self._normalize_warp_port_specs(ports_raw)
                if not port_specs and endpoints:
                    port_specs = self._normalize_warp_port_specs([ep.get("port") for ep in endpoints])
                if not port_specs:
                    port_specs = self._collect_warp_port_specs_from_args(args)

                if not port_specs:
                    return None

                return {
                    "name": name,
                    "args": args,
                    "port_specs": port_specs,
                    "protocols": protocols,
                    "masque_options": masque_options,
                    "endpoints": endpoints,
                    "prefer_exact_endpoints": prefer_exact_endpoints,
                }
            except:
                return None

        def _load_warp_bootstrap_profiles(self):
            profiles = []
            try:
                if not os.path.exists(self.warp_bootstrap_profiles_path):
                    return profiles
                with open(self.warp_bootstrap_profiles_path, "r", encoding="utf-8") as f:
                    data = json.load(f)
            except:
                return profiles

            raw_profiles = []
            if isinstance(data, dict) and isinstance(data.get("strategies"), list):
                raw_profiles = data.get("strategies", [])
            elif isinstance(data, dict):
                for key, value in data.items():
                    if key == "version":
                        continue
                    raw_profiles.append({"name": key, "args": value if isinstance(value, list) else []})
            elif isinstance(data, list):
                raw_profiles = data

            for idx, raw_profile in enumerate(raw_profiles, start=1):
                profile = self._normalize_warp_bootstrap_profile(raw_profile, idx)
                if profile:
                    profiles.append(profile)
            return profiles

        def _load_preferred_warp_bootstrap_name(self):
            try:
                if not os.path.exists(self.warp_bootstrap_state_path):
                    return ""
                with open(self.warp_bootstrap_state_path, "r", encoding="utf-8") as f:
                    data = json.load(f)
                if not isinstance(data, dict):
                    return ""
                ts = float(data.get("ts", 0) or 0)
                if ts > 0 and (time.time() - ts) > 30 * 86400:
                    return ""
                return str(data.get("name", "") or "").strip()
            except:
                return ""

        def _remember_successful_warp_bootstrap(self, profile_name):
            try:
                profile_name = str(profile_name or "").strip()
                if not profile_name:
                    return
                os.makedirs(self.temp_dir, exist_ok=True)
                with open(self.warp_bootstrap_state_path, "w", encoding="utf-8") as f:
                    json.dump({"name": profile_name, "ts": int(time.time())}, f, indent=2, ensure_ascii=False)
            except:
                pass

        def _get_ordered_warp_bootstrap_profiles(self):
            profiles = self._load_warp_bootstrap_profiles()
            if not profiles:
                fallback = self._normalize_warp_bootstrap_profile(
                    {
                        "name": "legacy-inline",
                        "ports": [443, 500, 1701, 4500],
                        "args": [
                            "--dpi-desync=fake",
                            "--dpi-desync-repeats=10",
                            "--dpi-desync-fake-quic=fake/quic_initial_www_google_com.bin"
                        ],
                    },
                    1,
                )
                if fallback:
                    profiles = [fallback]

            preferred_name = self._load_preferred_warp_bootstrap_name()
            if preferred_name:
                preferred = [p for p in profiles if p.get("name") == preferred_name]
                others = [p for p in profiles if p.get("name") != preferred_name]
                profiles = preferred + others
            return profiles

        def _build_warp_bootstrap_command(self, profile):
            try:
                winws_path = os.path.join(self.bin_dir, WINWS_FILENAME)
                warp_ipset_path = os.path.join(get_base_dir(), "ip", "warp.txt")
                if not os.path.exists(winws_path) or not file_has_noncomment_entries(warp_ipset_path):
                    return None

                port_specs = list(profile.get("port_specs") or [])
                if not port_specs:
                    return None

                args = list(profile.get("args") or [])
                user_has_filter_udp = any(isinstance(arg, str) and arg.startswith("--filter-udp=") for arg in args)
                user_has_wf_udp = any(isinstance(arg, str) and arg.startswith("--wf-udp=") for arg in args)
                ports_arg = ",".join(port_specs)

                cmd = [winws_path]
                if not user_has_wf_udp:
                    cmd.append(f"--wf-udp={ports_arg}")
                if not user_has_filter_udp:
                    cmd.append(f"--filter-udp={ports_arg}")

                cmd.append(f"--ipset={warp_ipset_path}")

                loopback_exclude_path = os.path.join(get_base_dir(), "temp", "loopback_exclude_ipset.txt")
                if file_has_noncomment_entries(loopback_exclude_path):
                    cmd.append(f"--ipset-exclude={loopback_exclude_path}")

                for arg in args:
                    if not isinstance(arg, str):
                        continue
                    arg = arg.strip()
                    if not arg:
                        continue
                    if arg in ("--dpi-desync-any-protocol", "--dpi-desync-any-proto"):
                        arg = "--dpi-desync-any-protocol=1"
                    if arg.startswith("--wf-udp=") and not user_has_wf_udp:
                        continue
                    if "=" in arg and ".bin" in arg:
                        k, v = arg.split("=", 1)
                        fname = os.path.basename(v)
                        fake_path = os.path.join(get_fake_dir(), fname)
                        if os.path.exists(fake_path):
                            arg = f"{k}={os.path.join(get_base_dir(), 'fake', fname)}"
                    cmd.append(arg)
                return cmd
            except:
                return None

        def _start_warp_bootstrap_process(self, profile):
            self._stop_warp_bootstrap_process()
            cmd = self._build_warp_bootstrap_command(profile)
            if not cmd:
                return False
            try:
                cmd_dump_path = os.path.join(get_base_dir(), "temp", "warp_bootstrap_last_command.txt")
                os.makedirs(os.path.dirname(cmd_dump_path), exist_ok=True)
                with open(cmd_dump_path, "w", encoding="utf-8") as f:
                    f.write(" ".join(cmd))
                    f.write("\n")
            except:
                pass

            try:
                proc = subprocess.Popen(
                    cmd,
                    cwd=get_base_dir(),
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    creationflags=subprocess.CREATE_NO_WINDOW,
                )
                time.sleep(0.9)
                if proc.poll() is not None:
                    try:
                        self.log_func(f"[RU] [Diag] Bootstrap winws завершился сразу (код {proc.poll()}) для профиля {profile.get('name', 'unknown')}.")
                    except:
                        pass
                    return False
                self.bootstrap_winws_process = proc
                self.bootstrap_winws_profile_name = str(profile.get("name", "") or "").strip()
                return True
            except:
                return False

        def _stop_warp_bootstrap_process(self):
            proc = getattr(self, "bootstrap_winws_process", None)
            self.bootstrap_winws_process = None
            self.bootstrap_winws_profile_name = ""
            if not proc:
                return
            try:
                if proc.poll() is None:
                    proc.terminate()
                    try:
                        proc.wait(timeout=2)
                    except:
                        try:
                            proc.kill()
                        except:
                            pass
                else:
                    try:
                        proc.wait(timeout=0.5)
                    except:
                        pass
            except:
                pass

        def _load_warp_connect_profile(self):
            try:
                if not os.path.exists(self.warp_connect_profile_path):
                    return None
                with open(self.warp_connect_profile_path, "r", encoding="utf-8") as f:
                    data = json.load(f)
                if isinstance(data, dict):
                    return data
            except:
                pass
            return None

        def _save_warp_connect_profile(self, profile):
            try:
                if not isinstance(profile, dict):
                    return False
                os.makedirs(self.temp_dir, exist_ok=True)
                with open(self.warp_connect_profile_path, "w", encoding="utf-8") as f:
                    json.dump(profile, f, indent=2, ensure_ascii=False)
                return True
            except:
                return False

        def _remember_successful_connect_profile(self, protocol="MASQUE", masque_option="h3-with-h2-fallback", ip_mode="auto", endpoint_host=None, endpoint_port=None):
            try:
                profile = {
                    "protocol": str(protocol or "MASQUE"),
                    "masque_option": str(masque_option or "h3-with-h2-fallback"),
                    "ip_mode": str(ip_mode or "auto").lower(),
                    "port": int(self.port),
                    "ts": int(time.time()),
                }
                endpoint_host = str(endpoint_host or "").strip()
                if endpoint_host:
                    profile["endpoint_host"] = endpoint_host
                if endpoint_port:
                    try:
                        endpoint_port = int(endpoint_port)
                    except:
                        endpoint_port = None
                    if endpoint_port and 1 <= endpoint_port <= 65535:
                        profile["endpoint_port"] = int(endpoint_port)
                self._save_warp_connect_profile(profile)
            except:
                pass

        def _get_preferred_connect_profile(self):
            profile = self._load_warp_connect_profile()
            if not profile:
                return None
            try:
                ts = float(profile.get("ts", 0) or 0)
                # Expire stale profile after 30 days.
                if ts > 0 and (time.time() - ts) > 30 * 86400:
                    return None

                protocol = str(profile.get("protocol", "MASQUE")).strip() or "MASQUE"
                if protocol not in ("MASQUE", "WireGuard"):
                    protocol = "MASQUE"

                masque_option = str(profile.get("masque_option", "h3-with-h2-fallback")).strip() or "h3-with-h2-fallback"
                if masque_option not in ("h3-with-h2-fallback", "h2-only", "h3-only", "reset"):
                    masque_option = "h3-with-h2-fallback"

                ip_mode = str(profile.get("ip_mode", "auto")).strip().lower() or "auto"
                if ip_mode not in ("auto", "v4", "v6"):
                    ip_mode = "auto"

                port = int(profile.get("port", self.port) or self.port)
                if not (1 <= port <= 65535):
                    port = int(self.port)

                endpoint_port = profile.get("endpoint_port", None)
                try:
                    endpoint_port = int(endpoint_port) if endpoint_port is not None else None
                except:
                    endpoint_port = None
                if endpoint_port is not None and not (1 <= endpoint_port <= 65535):
                    endpoint_port = None
                endpoint_host = str(profile.get("endpoint_host", "") or "").strip()

                return {
                    "protocol": protocol,
                    "masque_option": masque_option,
                    "ip_mode": ip_mode,
                    "port": port,
                    "endpoint_host": endpoint_host,
                    "endpoint_port": endpoint_port,
                }
            except:
                return None

        def _is_cli_cmd_unsupported(self, err_text):
            text = str(err_text or "").lower()
            return any(
                marker in text for marker in (
                    "unrecognized subcommand",
                    "unknown option",
                    "unknown argument",
                    "found argument",
                    "usage:",
                    "a similar subcommand exists",
                )
            )

        def _apply_ip_mode(self, ip_mode):
            mode = str(ip_mode or "auto").strip().lower()
            if mode not in ("auto", "v4", "v6"):
                mode = "auto"

            cached = self._ip_mode_cmd_cache.get(mode, None)
            if cached is False:
                return mode == "auto"
            if isinstance(cached, tuple):
                result = self.run_warp_cli(*cached)
                if result and result.returncode == 0:
                    return True
                # Force re-probe if previously working command now fails.
                self._ip_mode_cmd_cache.pop(mode, None)

            cmd_map = {
                "auto": [
                    ("tunnel", "ip", "reset"),
                    ("tunnel", "ip-version", "reset"),
                ],
                "v4": [
                    ("tunnel", "ip", "set", "v4"),
                    ("tunnel", "ip", "set", "4"),
                    ("tunnel", "ip-version", "set", "4"),
                    ("tunnel", "ip-version", "set", "v4"),
                ],
                "v6": [
                    ("tunnel", "ip", "set", "v6"),
                    ("tunnel", "ip", "set", "6"),
                    ("tunnel", "ip-version", "set", "6"),
                    ("tunnel", "ip-version", "set", "v6"),
                ],
            }

            last_err = ""
            unsupported_only = True
            for cmd in cmd_map.get(mode, []):
                result = self.run_warp_cli(*cmd)
                if result and result.returncode == 0:
                    self._ip_mode_cmd_cache[mode] = cmd
                    return True
                err = ""
                if result:
                    err = (result.stderr or result.stdout or "").strip()
                if err:
                    last_err = err
                if not self._is_cli_cmd_unsupported(err):
                    unsupported_only = False

            if unsupported_only:
                self._ip_mode_cmd_cache[mode] = False
                if mode != "auto" and not self._ip_mode_unsupported_logged:
                    self._ip_mode_unsupported_logged = True
                    self.log_func("[RU] [Diag] Текущий warp-cli не поддерживает выбор IP-версии (v4/v6).")
                return mode == "auto"

            if mode != "auto" and last_err:
                self.log_func(f"[RU] [Diag] Не удалось применить IP-режим {mode}: {last_err}")
            return mode == "auto"

        def _build_connect_attempts(self, preferred_profile=None):
            attempts = []
            seen = set()

            def _add(label, protocol, masque_option, ip_mode, timeout_sec, port=None):
                key = (str(protocol), str(masque_option), str(ip_mode), int(port or 0))
                if key in seen:
                    return
                seen.add(key)
                attempts.append(
                    {
                        "label": label,
                        "protocol": protocol,
                        "masque_option": masque_option,
                        "ip_mode": ip_mode,
                        "timeout": int(timeout_sec),
                        "port": int(port) if port else None,
                    }
                )

            if preferred_profile:
                _add(
                    "последний успешный профиль",
                    preferred_profile.get("protocol", "MASQUE"),
                    preferred_profile.get("masque_option", "h3-with-h2-fallback"),
                    preferred_profile.get("ip_mode", "auto"),
                    20,
                    preferred_profile.get("port"),
                )

            _add("MASQUE endpoint default (Auto)", "MASQUE", "h3-with-h2-fallback", "auto", 25)
            _add("MASQUE h2-only", "MASQUE", "h2-only", "auto", 20)
            _add("MASQUE h3-only", "MASQUE", "h3-only", "auto", 20)
            _add("WireGuard (Auto)", "WireGuard", "reset", "auto", 20)

            # Secondary rotation by IP family in case one side is filtered by ISP.
            for mode in ("v4", "v6"):
                _add(f"MASQUE endpoint default ({mode.upper()})", "MASQUE", "h3-with-h2-fallback", mode, 18)
                _add(f"MASQUE h2-only ({mode.upper()})", "MASQUE", "h2-only", mode, 18)
                _add(f"WireGuard ({mode.upper()})", "WireGuard", "reset", mode, 18)

            return attempts

        def mark_bootstrap(self, ok):
            try:
                self.bootstrap_ok = bool(ok)
                self.bootstrap_event.set()
            except:
                pass

        def wait_for_bootstrap(self, timeout=25):
            try:
                self.bootstrap_event.wait(timeout=max(0, timeout))
                return bool(self.bootstrap_ok)
            except:
                return False

        def _run_sc(self, *args, timeout=20):
            try:
                result = subprocess.run(
                    ["sc"] + list(args),
                    capture_output=True,
                    timeout=timeout,
                    creationflags=subprocess.CREATE_NO_WINDOW
                )
                return (
                    result.returncode,
                    self.decode_output(result.stdout),
                    self.decode_output(result.stderr)
                )
            except Exception as e:
                return -1, "", str(e)

        def _set_service_proxy_environment(self, enable_proxy=True):
            """Set service-specific proxy env so LocalSystem daemon can reach Cloudflare API."""
            try:
                import winreg
                reg_path = fr"SYSTEM\CurrentControlSet\Services\{self.SERVICE_NAME}"
                key = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, reg_path, 0, winreg.KEY_SET_VALUE)

                if enable_proxy:
                    env = [
                        "HTTP_PROXY=http://127.0.0.1:1371",
                        "HTTPS_PROXY=http://127.0.0.1:1371",
                        "NO_PROXY=127.0.0.1,localhost,::1",
                        "http_proxy=http://127.0.0.1:1371",
                        "https_proxy=http://127.0.0.1:1371",
                        "no_proxy=127.0.0.1,localhost,::1",
                    ]
                    winreg.SetValueEx(key, "Environment", 0, winreg.REG_MULTI_SZ, env)
                    if IS_DEBUG_MODE:
                        self.log_func("[RU] [Diag] Прокси-окружение службы CloudflareWARP установлено (127.0.0.1:1371).")
                else:
                    try:
                        winreg.DeleteValue(key, "Environment")
                        if IS_DEBUG_MODE:
                            self.log_func("[RU] [Diag] Прокси-окружение службы CloudflareWARP очищено.")
                    except FileNotFoundError:
                        pass

                winreg.CloseKey(key)
            except Exception as e:
                if IS_DEBUG_MODE:
                    self.log_func(f"[RU] [Diag] Не удалось обновить Environment службы: {e}")

        def _detect_service_bootstrap_transport(self):
            """Detect whether service env is configured to use local 127.0.0.1:1371 proxy."""
            try:
                import winreg
                reg_path = fr"SYSTEM\CurrentControlSet\Services\{self.SERVICE_NAME}"
                key = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, reg_path, 0, winreg.KEY_READ)
                try:
                    env_val = winreg.QueryValueEx(key, "Environment")[0]
                except FileNotFoundError:
                    env_val = []
                finally:
                    winreg.CloseKey(key)

                if isinstance(env_val, str):
                    env_items = [env_val]
                elif isinstance(env_val, (list, tuple)):
                    env_items = [str(x) for x in env_val]
                else:
                    env_items = []

                joined = "\n".join(env_items).lower()
                if "127.0.0.1:1371" in joined:
                    return "opera_1371"
                return "strategy"
            except:
                return "unknown"

        def _bootstrap_1371_suffix(self):
            """Human-readable suffix for connection logs."""
            if self.last_bootstrap_transport == "opera_1371":
                return " [через резерв 1371]"
            return ""

        def _check_direct_cloudflare_api(self, timeout=8):
            """Return True if direct HTTPS to Cloudflare API is reachable (without proxy)."""
            try:
                import urllib.request
                import urllib.error

                # Check both host forms: normal and trailing-dot FQDN used by daemon logs.
                endpoints = [
                    "https://api.cloudflareclient.com/v0/reg",
                    "https://api.cloudflareclient.com./v0/reg",
                ]
                opener = urllib.request.build_opener(urllib.request.ProxyHandler({}))

                for url in endpoints:
                    req = urllib.request.Request(url, method="GET")
                    try:
                        with opener.open(req, timeout=timeout):
                            return True
                    except urllib.error.HTTPError:
                        # Any HTTP response means transport path is reachable.
                        return True
                    except:
                        continue
            except:
                pass
            return False

        def _ensure_opera_proxy_ready(self, timeout=12):
            """Ensure local Opera proxy is reachable on 127.0.0.1:1371."""
            import socket
            try:
                opm = globals().get("opera_proxy_manager")
                if opm:
                    opm.start()
            except:
                pass

            start_t = time.time()
            while time.time() - start_t < timeout:
                if is_closing:
                    return False
                try:
                    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                        s.settimeout(0.4)
                        if s.connect_ex(('127.0.0.1', 1371)) == 0:
                            return True
                except:
                    pass
                time.sleep(0.25)
            return False

        def is_service_installed(self):
            """Check if CloudflareWARP service is installed."""
            rc, _, _ = self._run_sc("query", self.SERVICE_NAME)
            return rc == 0

        def is_service_running(self):
            """Check if CloudflareWARP service is running."""
            rc, out, _ = self._run_sc("query", self.SERVICE_NAME)
            return rc == 0 and "RUNNING" in (out or "").upper()
        
        def _log_warp_service_log_tail(self, lines=12):
            try:
                pdata = os.environ.get('ProgramData', 'C:\\ProgramData')
                cf_dir = os.path.join(pdata, "Cloudflare")
                candidates = [
                    ("warp-svc.log", os.path.join(cf_dir, "warp-svc.log")),
                    ("cfwarp_service_log.txt", os.path.join(cf_dir, "cfwarp_service_log.txt")),
                ]

                found_any = False
                for label, path in candidates:
                    if not os.path.exists(path):
                        continue

                    found_any = True
                    with open(path, "r", errors="ignore") as f:
                        all_lines = f.readlines()
                    tail = all_lines[-lines:]
                    if tail:
                        self.log_func(f"[RU] [Diag] Последние строки {label}:")
                        for line in tail:
                            line = line.rstrip()
                            if line:
                                low = line.lower()
                                # Skip ultra-noisy telemetry blobs to keep startup logs readable.
                                if "upload_stats{" in low or "statspayload" in low:
                                    continue
                                if len(line) > 520:
                                    line = line[:520] + " ...[truncated]"
                                self.log_func(f"[RU] [Diag] {line}")
                    else:
                        self.log_func(f"[RU] [Diag] {label} найден, но пуст.")

                    # Detect known hang pattern: daemon watchdog kill on API timeout.
                    recent = [ln.lower() for ln in all_lines[-220:]]
                    if any("warp ipc listening" in ln for ln in recent):
                        self.log_func("[RU] [Diag] Daemon поднял IPC, но завис в main loop.")
                    if any(("api.cloudflareclient.com" in ln and "timedout" in ln) for ln in recent):
                        self.log_func("[RU] [Diag] Есть таймауты к api.cloudflareclient.com (прямой выход из daemon блокируется/ломается).")
                    if any("watchdog is shutting down an overly hung daemon" in ln for ln in recent):
                        self.log_func("[RU] [Diag] Daemon остановлен watchdog из-за зависания.")

                if not found_any:
                    self.log_func("[RU] [Diag] Логи службы Cloudflare не найдены в ProgramData\\Cloudflare.")
            except Exception as e:
                self.log_func(f"[RU] [Diag] Ошибка чтения логов службы: {e}")

        def _log_service_diagnostics(self):
            for cmd in (
                ("query", self.SERVICE_NAME),
                ("queryex", self.SERVICE_NAME),
                ("qc", self.SERVICE_NAME),
            ):
                rc, out, err = self._run_sc(*cmd)
                msg = (out or err or "").strip().replace("\r", " ").replace("\n", " | ")
                if len(msg) > 420:
                    msg = msg[:420] + "..."
                self.log_func(f"[RU] [Diag] sc {' '.join(cmd)} -> rc={rc}; {msg or 'no output'}")

        def _ensure_service_registered(self):
            quoted_path = f'"{self.warp_svc_path}"'

            rc, out, err = self._run_sc("query", self.SERVICE_NAME)
            query_msg = f"{out}\n{err}".lower()
            service_missing = (
                rc != 0 and (
                    "1060" in query_msg or
                    "does not exist" in query_msg or
                    "не существует" in query_msg
                )
            )

            if service_missing:
                rc, out, err = self._run_sc(
                    "create", self.SERVICE_NAME,
                    "binPath=", quoted_path,
                    "type=", "own",
                    "start=", "demand",
                    "obj=", "LocalSystem",
                    "DisplayName=", "Cloudflare WARP (Nova)"
                )
                if rc != 0:
                    msg = (err or out or f"code {rc}").strip()
                    self.log_func(f"[RU] Ошибка создания службы: {msg}")
                    return False

            rc, out, err = self._run_sc(
                "config", self.SERVICE_NAME,
                "binPath=", quoted_path,
                "type=", "own",
                "start=", "demand",
                "obj=", "LocalSystem",
                "DisplayName=", "Cloudflare WARP (Nova)"
            )
            if rc != 0:
                msg = (err or out or f"code {rc}").strip()
                self.log_func(f"[RU] Ошибка конфигурации службы: {msg}")
                return False

            return True

        def start_service(self):
            """Start warp-svc.exe as a deterministic Windows service."""
            try:
                if not os.path.exists(self.warp_svc_path):
                    self.log_func(f"[RU] ОШИБКА: Бинарный файл {self.warp_svc_path} не найден!")
                    return False

                # Keep WARP helper GUI processes away from service bootstrap.
                for proc_name in ["warp-taskbar.exe", "Cloudflare WARP.exe", "warp-cli.exe", "warp-svc.exe"]:
                    subprocess.run(
                        ["taskkill", "/F", "/IM", proc_name, "/T"],
                        capture_output=True,
                        creationflags=subprocess.CREATE_NO_WINDOW
                    )

                try:
                    pdata = os.environ.get('ProgramData', 'C:\\ProgramData')
                    cf_dir = os.path.join(pdata, "Cloudflare")
                    os.makedirs(cf_dir, exist_ok=True)
                except:
                    pass

                def _start_and_wait_ipc():
                    rc, out, err = self._run_sc("start", self.SERVICE_NAME, timeout=12)
                    start_msg = f"{out}\n{err}".lower()
                    if rc != 0 and not any(x in start_msg for x in ["1056", "already running", "already been started"]):
                        return False, "Unknown", (err or out or f"code {rc}").strip()

                    self.log_func("[RU] Ожидание инициализации службы...")
                    last_status = "Unknown"
                    last_error = ""
                    for _ in range(50):
                        if is_closing:
                            return False, last_status, "closing"

                        if not self.is_service_running():
                            time.sleep(0.4)
                            continue

                        status_result = self.run_warp_cli("status", timeout=8)
                        if status_result:
                            status_text = (status_result.stdout or "").strip()
                            err_text = (status_result.stderr or "").strip()
                            status_low = status_text.lower()
                            # Important: "Registration Missing ... Daemon Startup" means IPC is up and daemon is alive.
                            # Treat it as ready so upper layers can run registration flow instead of failing startup.
                            if status_result.returncode == 0 and status_text:
                                if "registration missing" in status_low:
                                    return True, status_text, ""
                                if "unable" not in status_low and "unknown" not in status_low:
                                    return True, status_text, ""
                            if status_text:
                                last_status = status_text
                            if err_text:
                                last_error = err_text
                        else:
                            last_error = "timeout"

                        time.sleep(0.5)

                    return False, last_status, last_error

                self._run_sc("stop", self.SERVICE_NAME, timeout=10)
                time.sleep(0.8)

                self.log_func("[RU] Установка и запуск службы...")
                if not self._ensure_service_registered():
                    self._log_service_diagnostics()
                    return False

                # Primary mode: Cloudflare bootstrap through active winws strategy (strategies.json).
                # If this path fails, reserve fallback through Opera proxy is attempted below.
                self.last_bootstrap_transport = "strategy"
                self._set_service_proxy_environment(enable_proxy=False)
                self.log_func("[RU] [Diag] Режим запуска WARP: strategy (Cloudflare через winws/strategies.json).")

                ok, last_status, last_error = _start_and_wait_ipc()
                if ok:
                    return True

                # Retry once in the same strategy-only mode (service can race on first boot).
                strategy_ok = ok
                if not is_closing:
                    self.log_func("[RU] [Warning] Первая попытка не подняла IPC. Повтор запуска в strategy-режиме...")
                    self._run_sc("stop", self.SERVICE_NAME, timeout=10)
                    time.sleep(0.8)
                    self._set_service_proxy_environment(enable_proxy=False)
                    ok2, status2, err2 = _start_and_wait_ipc()
                    if ok2:
                        self.log_func("[RU] [Diag] Служба поднялась со второй попытки в strategy-режиме.")
                        return True
                    if status2:
                        last_status = status2
                    if err2:
                        last_error = err2
                    strategy_ok = ok2

                # User policy: if strategy path failed, fallback through Opera proxy as reserve.
                if not is_closing and not strategy_ok:
                    self.log_func("[RU] [Warning] Strategy-режим не поднял IPC. Пробуем резерв через Opera VPN прокси...")
                    if self._ensure_opera_proxy_ready(timeout=15):
                        self._run_sc("stop", self.SERVICE_NAME, timeout=10)
                        time.sleep(0.8)
                        self._set_service_proxy_environment(enable_proxy=True)
                        self.last_bootstrap_transport = "opera_1371"
                        ok3, status3, err3 = _start_and_wait_ipc()
                        if ok3:
                            self.log_func("[RU] [Diag] Служба поднялась через резерв Opera VPN прокси.")
                            return True
                        if status3:
                            last_status = status3
                        if err3:
                            last_error = err3
                    else:
                        self.log_func("[RU] [Warning] Резерв Opera VPN прокси недоступен.")

                self.log_func("[RU] [Warning] Служба не отвечает на IPC.")
                if last_status and last_status != "Unknown":
                    self.log_func(f"[RU] [Diag] Последний статус: {last_status}")
                if last_error:
                    self.log_func(f"[RU] [Diag] Последняя ошибка warp-cli: {last_error}")

                self._log_service_diagnostics()
                self._log_warp_service_log_tail()
                self.log_func("[RU] [Hint] Проверьте доступность api/engage/connectivity.cloudflareclient.com в текущей сети (без авто-правок general/exclude).")
                # Never leave CloudflareWARP service bound to 1371 after failed bootstrap.
                try:
                    self._set_service_proxy_environment(enable_proxy=False)
                except:
                    pass
                return False
            except Exception as e:
                try:
                    self._set_service_proxy_environment(enable_proxy=False)
                except:
                    pass
                self.log_func(f"[RU] Ошибка запуска службы: {e}")
                return False

        def ensure_service(self):
            """Ensure warp-svc.exe is running as a service."""
            # Startup hygiene: clear stale per-service proxy env from previous runs.
            try:
                self._set_service_proxy_environment(enable_proxy=False)
            except:
                pass
            # If service is already running and IPC is responsive, don't restart it
            if self.is_service_running():
                status = self.get_status()
                if status and "Unable" not in status and "Unknown" not in status:
                    self.last_bootstrap_transport = self._detect_service_bootstrap_transport()
                    if self.last_bootstrap_transport == "opera_1371":
                        self.log_func("[RU] [Diag] Служба уже активна: bootstrap через резерв 1371.")
                    return True
            
            # Otherwise, perform a clean restart
            return self.start_service()

        def run_warp_cli(self, *args, timeout=30):
            """Run warp-cli command and return result."""
            if not os.path.exists(self.warp_cli_path) or is_closing:
                return None
                
            try:
                cmd = [self.warp_cli_path] + list(args)
                
                # Setup Environment
                env = os.environ.copy()
                # Prevent inherited proxies from breaking local daemon IPC.
                for key in ["HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY", "http_proxy", "https_proxy", "all_proxy"]:
                    env.pop(key, None)
                env["NO_PROXY"] = "127.0.0.1,localhost,::1"
                env["no_proxy"] = "127.0.0.1,localhost,::1"
                
                is_reg_cmd = any(x in args for x in ["registration", "account", "license"])
                
                if is_reg_cmd and not is_closing:
                    # Strict strategy mode: do not bypass via local Opera proxy.
                    # Registration/account traffic must follow active winws strategy rules.
                    if IS_DEBUG_MODE and not globals().get('is_service_active', False):
                        self.log_func("[RU] [Diag] registration/account запущен без активного ядра: стратегия может быть недоступна.")

                if is_closing: return None

                startupinfo = subprocess.STARTUPINFO()
                startupinfo.dwFlags |= subprocess.STARTF_USESHOWWINDOW
                
                result = subprocess.run(
                    cmd,
                    capture_output=True,
                    timeout=timeout,
                    creationflags=subprocess.CREATE_NO_WINDOW,
                    startupinfo=startupinfo,
                    env=env
                )
                
                # Manual decode to fix encoding issues on localized Windows
                if result:
                    result.stdout = self.decode_output(result.stdout)
                    result.stderr = self.decode_output(result.stderr)

                return result
            except subprocess.TimeoutExpired:
                if IS_DEBUG_MODE and not is_closing: self.log_func(f"[RU] Команда таймаут: {' '.join(args)}")
                return None
            except Exception as e:
                if not is_closing: self.log_func(f"[RU] Ошибка команды: {e}")
                return None
        
        def get_status(self):
            """Get current WARP connection status."""
            if getattr(self, "active_backend", "") == "awg":
                try:
                    proc = getattr(self, "awg_process", None)
                    if proc and proc.poll() is None:
                        if self.is_connected or self._is_awg_backend_healthy(timeout=1.6):
                            self.is_connected = True
                            return f"Connected (AWG: {self.awg_active_profile_name or 'profile'})"
                        return f"Connecting (AWG: {self.awg_active_profile_name or 'profile'})"
                except:
                    pass
                try:
                    if self._is_awg_backend_healthy(timeout=1.6):
                        self.is_connected = True
                        return f"Connected (AWG: {self.awg_active_profile_name or 'profile'})"
                except:
                    pass
                self.is_connected = False
                return "Disconnected (AWG)"
            result = self.run_warp_cli("status")
            if result and result.returncode == 0:
                return result.stdout.strip()
            return "Unknown"

        def _warp_cli_result_text(self, result):
            try:
                if not result:
                    return ""
                parts = []
                out = self.decode_output(getattr(result, "stdout", ""))
                err = self.decode_output(getattr(result, "stderr", ""))
                if out:
                    parts.append(out.strip())
                if err:
                    parts.append(err.strip())
                return "\n".join(part for part in parts if part).strip()
            except:
                return ""

        def _is_warp_daemon_unreachable_text(self, text):
            low = str(text or "").strip().lower()
            if not low:
                return False
            markers = [
                "unable to connect to the cloudflarewarp daemon",
                "maybe the daemon is not running",
                "os error 2",
                "не удается найти указанный файл",
                "error communicating with daemon",
            ]
            return any(marker in low for marker in markers)

        def _is_registration_conflict_text(self, text):
            low = str(text or "").strip().lower()
            if not low:
                return False
            markers = [
                "old registration is still around",
                "try running: \"warp-cli registration delete\"",
                "registration delete",
                "already exists",
                "conflict",
            ]
            return any(marker in low for marker in markers)

        def _is_registration_missing_text(self, text):
            low = str(text or "").strip().lower()
            if not low:
                return False
            markers = [
                "registration missing",
                "does not exist in api",
                "not registered",
                "missing due to",
            ]
            return any(marker in low for marker in markers)

        def _clear_registration_backoff(self):
            self._registration_backoff_until = 0.0
            self._registration_backoff_reason = ""
            self._registration_backoff_notice_ts = 0.0

        def _set_registration_backoff(self, seconds=45.0, reason=""):
            try:
                self._registration_backoff_until = max(float(self._registration_backoff_until or 0.0), time.time() + max(5.0, float(seconds or 0.0)))
                self._registration_backoff_reason = str(reason or "").strip()
            except:
                pass

        def _probe_registration_state(self):
            result = self.run_warp_cli("registration", "show", timeout=10)
            text = self._warp_cli_result_text(result)
            has_registration = bool(result and result.returncode == 0 and text and "account type:" in text.lower())
            missing = self._is_registration_missing_text(text)
            return has_registration, missing, text

        def _clear_stale_registration_conflict(self):
            """Resolve 'Old registration is still around' without looping forever."""
            try:
                try:
                    self.run_warp_cli("disconnect", timeout=8)
                except:
                    pass

                delete_text = ""
                for _ in range(2):
                    delete_result = self.run_warp_cli("registration", "delete", timeout=15)
                    delete_text = self._warp_cli_result_text(delete_result)
                    low = delete_text.lower()
                    if delete_result and delete_result.returncode == 0:
                        break
                    if self._is_registration_missing_text(low):
                        break
                    time.sleep(1.0)

                # Important: registration delete alone is not enough on some builds.
                # Restart the daemon so it forgets stale in-memory registration state.
                try:
                    self._set_service_proxy_environment(enable_proxy=False)
                except:
                    pass
                self._restart_service_with_current_env(timeout=16)
                time.sleep(1.0)

                has_registration, missing, probe_text = self._probe_registration_state()
                if not has_registration:
                    return True

                if not self._deep_registration_reset_attempted:
                    self._deep_registration_reset_attempted = True
                    self.log_func("[RU] [Diag] Старая регистрация сохранилась после delete. Выполняем глубокую очистку WARP...")
                    if self.nuke_warp_data():
                        try:
                            self._set_service_proxy_environment(enable_proxy=False)
                        except:
                            pass
                        if self._ensure_service_registered():
                            self._restart_service_with_current_env(timeout=20)
                            time.sleep(1.0)
                            has_registration, missing, probe_text = self._probe_registration_state()
                            if not has_registration:
                                return True

                return False
            except Exception as e:
                if IS_DEBUG_MODE:
                    self.log_func(f"[RU] [Diag] Ошибка очистки stale registration: {e}")
                return False
        
        def ensure_masque(self):
            """Ensure MASQUE protocol is enabled."""
            result = self.run_warp_cli("settings", "list")
            if result and result.returncode == 0:
                if "MASQUE" not in result.stdout:
                    if IS_DEBUG_MODE: self.log_func("[RU] Переключение на протокол MASQUE...")
                    self.run_warp_cli("tunnel", "protocol", "set", "MASQUE")

        def _propagate_warp_port(self, port):
            """Synchronize active WARP SOCKS port across runtime components."""
            try:
                p = int(port)
            except:
                return
            changed = False
            try:
                if int(globals().get("WARP_PORT", p)) != p:
                    changed = True
                globals()["WARP_PORT"] = p
                globals()["WARP_PORT_LEGACY"] = p
            except:
                pass
            try:
                pm = globals().get("pac_manager")
                if pm:
                    pm_changed = False
                    try:
                        pm_changed = int(getattr(pm, "warp_port", p)) != p
                    except:
                        pm_changed = True
                    pm.warp_port = p
                    if pm_changed or changed:
                        try:
                            pm.generate_pac()
                            pm.refresh_system_options()
                        except:
                            pass
            except:
                pass

        def _get_proxy_port_candidates(self):
            out = []
            seen = set()

            def _add(v):
                try:
                    iv = int(v)
                except:
                    return
                if not (1 <= iv <= 65535):
                    return
                if iv in seen:
                    return
                seen.add(iv)
                out.append(iv)

            _add(self.port)
            _add(self.port_legacy)
            for p in (1370, 1372, 1374, 1080, 10808):
                _add(p)

            raw = str(os.environ.get("NOVA_WARP_PORT_CANDIDATES", "")).strip()
            if raw:
                for part in raw.replace(";", ",").split(","):
                    _add(part.strip())
            return out

        def _try_alternate_proxy_ports(self):
            """Try alternate local SOCKS ports when current port won't open on this host."""
            start_port = self.port
            for cand in self._get_proxy_port_candidates():
                prev = self.port
                if cand != prev:
                    self.log_func(f"[RU] [Diag] Пробуем резервный SOCKS порт {cand}...")
                if not self.set_proxy_port(cand):
                    continue
                self.set_proxy_mode()

                deadline = time.time() + 3.0
                while time.time() < deadline:
                    if self.is_port_open(cand):
                        self._propagate_warp_port(cand)
                        if cand != prev:
                            self.log_func(f"[RU] [Diag] Активирован резервный SOCKS порт {cand}.")
                        return True
                    time.sleep(0.25)
            # Restore original preference if no candidate produced a listener.
            if self.port != start_port:
                self.set_proxy_port(start_port)
                self.set_proxy_mode()
            return False
        
        def set_proxy_port(self, port):
            """Set WARP proxy port."""
            result = self.run_warp_cli("proxy", "port", str(port))
            if result and result.returncode == 0:
                self.port = port
                self._propagate_warp_port(port)
                self.log_func(f"[RU] Настройки порта ({port}) отправлены.")
                return True
            else:
                err = result.stderr.strip() if result else "Unknown error"
                self.log_func(f"[RU] ОШИБКА установки порта прокси {port}: {err}")
            return False
        
        def set_proxy_mode(self):
            """Set WARP to proxy mode (SOCKS on 1370)."""
            result = self.run_warp_cli("mode", "proxy")
            if result and result.returncode == 0:
                self.log_func("[RU] Команда режима прокси отправлена.")
                return True
            else:
                err = result.stderr.strip() if result else "Unknown error"
                self.log_func(f"[RU] ОШИБКА активации режима прокси: {err}")
            return False

        def _run_connect_attempt(self, attempt_cfg):
            protocol = str(attempt_cfg.get("protocol", "MASQUE"))
            masque_option = str(attempt_cfg.get("masque_option", "h3-with-h2-fallback"))
            ip_mode = str(attempt_cfg.get("ip_mode", "auto")).lower()
            timeout = int(attempt_cfg.get("timeout", 20) or 20)
            attempt_port = attempt_cfg.get("port", None)
            endpoint_host = str(attempt_cfg.get("endpoint_host", "") or "").strip()
            endpoint_port = attempt_cfg.get("endpoint_port", None)

            if attempt_port:
                try:
                    attempt_port = int(attempt_port)
                except:
                    attempt_port = None
            if endpoint_port:
                try:
                    endpoint_port = int(endpoint_port)
                except:
                    endpoint_port = None
            if attempt_port and attempt_port != self.port:
                self.set_proxy_port(attempt_port)

            if endpoint_port:
                if not endpoint_host:
                    endpoint_host = self._discover_warp_endpoint_host()
                self.run_warp_cli("tunnel", "endpoint", "set", f"{endpoint_host}:{int(endpoint_port)}")
            else:
                self.run_warp_cli("tunnel", "endpoint", "reset")

            proto_res = self.run_warp_cli("tunnel", "protocol", "set", protocol)
            if not proto_res or proto_res.returncode != 0:
                msg = (proto_res.stderr.strip() if proto_res else "timeout/unknown")
                self.log_func(f"[RU] [Diag] Не удалось применить protocol {protocol}: {msg}")

            if protocol == "MASQUE":
                if masque_option and masque_option != "reset":
                    tune_cmd = ("tunnel", "masque-options", "set", masque_option)
                else:
                    tune_cmd = ("tunnel", "masque-options", "reset")
            else:
                tune_cmd = ("tunnel", "masque-options", "reset")

            tune_res = self.run_warp_cli(*tune_cmd)
            if not tune_res or tune_res.returncode != 0:
                msg = (tune_res.stderr.strip() if tune_res else "timeout/unknown")
                self.log_func(f"[RU] [Diag] Не удалось применить {' '.join(tune_cmd)}: {msg}")

            # Some warp-cli builds reset local proxy mode/port after tunnel tweaks.
            self.set_proxy_port(self.port)
            self.set_proxy_mode()

            if ip_mode != "auto":
                if not self._apply_ip_mode(ip_mode):
                    self.log_func(f"[RU] [Diag] IP-режим {ip_mode} недоступен, попытка пропущена.")
                    return False

            self.run_warp_cli("connect")
            if self.wait_for_connection(timeout=timeout):
                self.is_connected = True
                self._remember_successful_connect_profile(protocol=protocol, masque_option=masque_option, ip_mode=ip_mode, endpoint_host=endpoint_host, endpoint_port=endpoint_port)
                return True
            return False

        def _legacy_connect_cycle(self):
            """Compatibility fallback: original sequence without IP-mode controls."""
            # 1) MASQUE default
            self.log_func("[RU] Подключение: MASQUE endpoint default (legacy fallback)...")
            self.run_warp_cli("tunnel", "endpoint", "reset")
            self.run_warp_cli("tunnel", "protocol", "set", "MASQUE")
            self.run_warp_cli("tunnel", "masque-options", "set", "h3-with-h2-fallback")
            self.set_proxy_port(self.port)
            self.set_proxy_mode()
            self.run_warp_cli("connect")
            if self.wait_for_connection(timeout=25):
                self.is_connected = True
                self._remember_successful_connect_profile(protocol="MASQUE", masque_option="h3-with-h2-fallback", ip_mode="auto")
                return True
            self.run_warp_cli("disconnect")
            time.sleep(0.8)

            # 2) Legacy fallback sequence
            fallback_attempts = [
                ("MASQUE", "MASQUE h2-only (legacy)", ("tunnel", "masque-options", "set", "h2-only")),
                ("MASQUE", "MASQUE h3-only (legacy)", ("tunnel", "masque-options", "set", "h3-only")),
                ("WireGuard", "WireGuard (Auto) (legacy)", ("tunnel", "masque-options", "reset")),
            ]

            for proto_cli, attempt_label, tune_cmd in fallback_attempts:
                self.run_warp_cli("tunnel", "endpoint", "reset")
                if tune_cmd:
                    tune_res = self.run_warp_cli(*tune_cmd)
                    if not tune_res or tune_res.returncode != 0:
                        msg = (tune_res.stderr.strip() if tune_res else "timeout/unknown")
                        self.log_func(f"[RU] [Diag] Не удалось применить {' '.join(tune_cmd)}: {msg}")

                self.log_func(f"[RU] Подключение: {attempt_label}...")
                proto_res = self.run_warp_cli("tunnel", "protocol", "set", proto_cli)
                if not proto_res or proto_res.returncode != 0:
                    msg = (proto_res.stderr.strip() if proto_res else "timeout/unknown")
                    self.log_func(f"[RU] [Diag] Не удалось применить protocol {proto_cli}: {msg}")
                self.set_proxy_port(self.port)
                self.set_proxy_mode()
                self.run_warp_cli("connect")
                if self.wait_for_connection(timeout=20):
                    self.is_connected = True
                    masq_opt = "reset"
                    if "h2-only" in attempt_label.lower():
                        masq_opt = "h2-only"
                    elif "h3-only" in attempt_label.lower():
                        masq_opt = "h3-only"
                    self._remember_successful_connect_profile(protocol=proto_cli, masque_option=masq_opt, ip_mode="auto")
                    return True
                self.run_warp_cli("disconnect")
                time.sleep(0.8)

            return False

        def _restart_service_with_current_env(self, timeout=14):
            """Restart service preserving already configured service Environment."""
            try:
                self._run_sc("stop", self.SERVICE_NAME, timeout=10)
            except:
                pass
            time.sleep(0.8)

            try:
                rc, out, err = self._run_sc("start", self.SERVICE_NAME, timeout=12)
                start_msg = f"{out}\n{err}".lower()
                if rc != 0 and not any(x in start_msg for x in ["1056", "already running", "already been started"]):
                    return False
            except:
                return False

            end_t = time.time() + max(6, int(timeout))
            while time.time() < end_t:
                if is_closing:
                    return False
                status = self.get_status()
                s_low = (status or "").lower()
                if status and ("registration missing" in s_low or ("unable" not in s_low and "unknown" not in s_low)):
                    return True
                time.sleep(0.4)
            return False

        def recover_connection(self, reason=""):
            """Best-effort runtime recovery for stuck/disconnected WARP sessions."""
            if is_closing:
                return False
            if getattr(self, "_is_starting_now", False) or getattr(self, "_is_recovering_now", False):
                return False

            self._is_recovering_now = True
            try:
                if getattr(self, "active_backend", "") == "awg":
                    if self._is_awg_backend_healthy(timeout=2.0):
                        self.is_connected = True
                        return True
                    self.is_connected = False
                    return self._recover_awg_backend(reason=reason)

                reason_txt = str(reason or "").strip()
                if reason_txt:
                    self.log_func(f"[RU] [Watchdog] Восстановление WARP: {reason_txt}.")
                else:
                    self.log_func("[RU] [Watchdog] Восстановление WARP...")

                daemon_probe = None
                daemon_text = ""
                daemon_restart_needed = False
                try:
                    daemon_probe = self.run_warp_cli("status", timeout=8)
                    daemon_text = self._warp_cli_result_text(daemon_probe)
                    daemon_restart_needed = (not self.is_service_running()) or self._is_warp_daemon_unreachable_text(daemon_text)
                except:
                    daemon_restart_needed = not self.is_service_running()

                if daemon_restart_needed:
                    self.log_func("[RU] [Diag] Daemon WARP недоступен. Перезапускаем службу перед восстановлением...")
                    try:
                        self._set_service_proxy_environment(enable_proxy=False)
                    except:
                        pass
                    if not self.start_service():
                        self.is_connected = False
                        return False
                else:
                    # Cheap repair first: local SOCKS settings may desync while daemon is still alive.
                    try:
                        self.set_proxy_port(self.port)
                        self.set_proxy_mode()
                        if self.wait_for_connection(timeout=8):
                            return True
                    except:
                        pass

                    try:
                        self.run_warp_cli("disconnect", timeout=8)
                    except:
                        pass
                    time.sleep(1.0)

                self.is_connected = False
                self.start()

                try:
                    if self.is_connected:
                        return bool(self.wait_for_connection(timeout=8))
                except:
                    pass
                return bool(self.is_connected and self.is_port_open(self.port))
            finally:
                self._is_recovering_now = False

        def _run_bootstrap_connection_cycle(self, my_run_id, bootstrap_profile=None):
            # Ensure service is running
            if not self.ensure_service():
                self.mark_bootstrap(False)
                self.log_func("[RU] Не удалось запустить службу!")
                return False

            # Wait for daemon to be responsive
            status = "Unknown"
            for _ in range(40):  # Up to 12s (40 * 0.3s)
                if is_closing or SERVICE_RUN_ID != my_run_id:
                    return False
                status = self.get_status()
                status_low = (status or "").lower()
                if status and ("registration missing" in status_low or ("unable" not in status_low and "unknown" not in status_low)):
                    break
                time.sleep(0.3)

            if SERVICE_RUN_ID != my_run_id:
                return False
            if "Unable to connect" in status or "Unknown" in status:
                reg_probe = self.run_warp_cli("registration", "show", timeout=8)
                if not reg_probe or reg_probe.returncode != 0:
                    self.mark_bootstrap(False)
                    self.log_func("[RU] Ошибка: Служба WARP не отвечает.")
                    return False
                if IS_DEBUG_MODE:
                    self.log_func("[RU] [Diag] status вернул Unknown, но IPC отвечает (registration show OK). Продолжаем.")
            else:
                self.mark_bootstrap(True)

            if "Registration Missing" in status:
                self.log_func("[RU] Регистрация устройства...")
                reg_success = False
                last_error = "Unknown error"
                for attempt in range(4):
                    if is_closing or SERVICE_RUN_ID != my_run_id:
                        return False
                    if attempt > 0:
                        time.sleep(1.5)

                    result = self.run_warp_cli("registration", "new")
                    out = result.stdout.strip() if (result and result.stdout) else ""
                    err = result.stderr.strip() if (result and result.stderr) else ""
                    last_error = f"{err} {out}".strip() or "Unknown error"

                    if result and result.returncode == 0:
                        self._clear_registration_backoff()
                        self._deep_registration_reset_attempted = False
                        self.log_func("[RU] Устройство зарегистрировано.")
                        reg_success = True
                        break

                    if "IPC call hit a timeout" in last_error or "Error communicating with daemon" in last_error:
                        self.log_func(f"[RU] Служба занята (попытка {attempt+1}/4).")
                        time.sleep(2)
                        continue

                    if self._is_registration_conflict_text(last_error):
                        self.log_func("[RU] Очистка старой регистрации...")
                        if self._clear_stale_registration_conflict():
                            continue
                        self._set_registration_backoff(45.0, "конфликт старой регистрации")
                        break
                    time.sleep(1)

                if not reg_success:
                    self.mark_bootstrap(False)
                    self._set_registration_backoff(45.0, last_error)
                    self.log_func(f"[RU] Ошибка регистрации: {last_error}")
                    return False
                status = self.get_status()

            if SERVICE_RUN_ID != my_run_id:
                return False

            self.run_warp_cli("tunnel", "endpoint", "reset")
            self.run_warp_cli("tunnel", "protocol", "reset")
            self.run_warp_cli("tunnel", "masque-options", "reset")

            self.ensure_masque()

            preferred_profile = self._get_preferred_connect_profile()
            if preferred_profile:
                try:
                    pref_port = int(preferred_profile.get("port", self.port))
                except:
                    pref_port = int(self.port)
                if pref_port != self.port:
                    self.port = pref_port
                    self.log_func(f"[RU] [Diag] Используем сохраненный порт {self.port} из успешного профиля.")

            self.set_proxy_port(self.port)
            self.set_proxy_mode()

            if "Connected" in status:
                self.log_func("[RU] [Diag] WARP уже сообщает Connected. Проверяем рабочий SOCKS/трафик...")
                connected_now = self.wait_for_connection(timeout=12)
                self.is_connected = bool(connected_now)
                if connected_now:
                    self.mark_bootstrap(True)
                    return True

                self.log_func("[RU] [Warning] WARP статус Connected, но соединение нерабочее. Перезапуск профиля...")
                try:
                    self.run_warp_cli("disconnect", timeout=8)
                except:
                    pass
                time.sleep(1.0)

            bootstrap_ports = []
            endpoint_candidates = []
            protocol_hints = None
            masque_option_hints = None
            prefer_exact_endpoints = False
            try:
                if isinstance(bootstrap_profile, dict):
                    bootstrap_ports = list(bootstrap_profile.get("port_specs") or [])
                    endpoint_candidates = list(bootstrap_profile.get("endpoints") or [])
                    protocol_hints = list(bootstrap_profile.get("protocols") or [])
                    masque_option_hints = list(bootstrap_profile.get("masque_options") or [])
                    prefer_exact_endpoints = bool(bootstrap_profile.get("prefer_exact_endpoints", False))
            except:
                bootstrap_ports = []
                endpoint_candidates = []
                protocol_hints = None
                masque_option_hints = None
                prefer_exact_endpoints = False

            for attempt_cfg in self._build_connect_attempts(
                preferred_profile,
                bootstrap_ports=bootstrap_ports,
                endpoint_candidates=endpoint_candidates,
                protocol_hints=protocol_hints,
                masque_option_hints=masque_option_hints,
                prefer_exact_endpoints=prefer_exact_endpoints,
            ):
                if is_closing or SERVICE_RUN_ID != my_run_id:
                    return False

                label = str(attempt_cfg.get("label", "Auto"))
                if "последний успешный профиль" in label:
                    self.log_func(f"[RU] Подключение: {label} (fallback)...")
                else:
                    self.log_func(f"[RU] Подключение: {label}...")

                if self._run_connect_attempt(attempt_cfg):
                    self.mark_bootstrap(True)
                    return True

                self.run_warp_cli("disconnect")
                time.sleep(0.8)

            self.log_func("[RU] [Diag] Основной цикл не сработал. Пробуем legacy-цикл подключения...")
            if self._legacy_connect_cycle():
                self.mark_bootstrap(True)
                return True

            try:
                can_try_opera_bootstrap = (
                    self.last_bootstrap_transport != "opera_1371"
                    and self._ensure_opera_proxy_ready(timeout=8)
                )
            except:
                can_try_opera_bootstrap = False

            if can_try_opera_bootstrap:
                self.log_func("[RU] [Diag] Пробуем аварийный bootstrap WARP через 127.0.0.1:1371...")
                try:
                    self._set_service_proxy_environment(enable_proxy=True)
                except:
                    pass
                if self._restart_service_with_current_env(timeout=16):
                    self.last_bootstrap_transport = "opera_1371"
                    self.set_proxy_port(self.port)
                    self.set_proxy_mode()
                    if self._legacy_connect_cycle():
                        self.mark_bootstrap(True)
                        return True
                else:
                    self.log_func("[RU] [Diag] Аварийный bootstrap через 1371 не поднял службу.")

            self.run_warp_cli("tunnel", "endpoint", "reset")
            self.run_warp_cli("tunnel", "masque-options", "reset")
            self.run_warp_cli("tunnel", "protocol", "reset")
            self.log_func("[RU] [Warning] Все попытки подключения исчерпаны.")
            return False

        def start(self):
            """Connect to WARP using temporary bootstrap strategies from warp.json."""
            if hasattr(self, '_is_starting_now') and self._is_starting_now:
                return

            self._is_starting_now = True
            self.bootstrap_ok = False
            try:
                self.bootstrap_event.clear()
            except:
                pass
            my_run_id = SERVICE_RUN_ID

            try:
                self._stop_awg_proxy_process(reset_backend=True, force_orphans=True)
                now_ts = time.time()
                if now_ts < float(getattr(self, "_registration_backoff_until", 0.0) or 0.0):
                    remaining = int(max(1.0, self._registration_backoff_until - now_ts))
                    if now_ts - float(getattr(self, "_registration_backoff_notice_ts", 0.0) or 0.0) >= 10.0:
                        self._registration_backoff_notice_ts = now_ts
                        suffix = f": {self._registration_backoff_reason}" if self._registration_backoff_reason else ""
                        self.log_func(f"[RU] [Diag] Повтор регистрации WARP отложен на {remaining}с{suffix}")
                    self.mark_bootstrap(False)
                    return

                if self._try_start_awg_profiles(my_run_id):
                    return

                profiles = self._get_ordered_warp_bootstrap_profiles()
                if not profiles:
                    self.mark_bootstrap(False)
                    self.log_func("[RU] [Warning] Не найдены bootstrap стратегии WARP.")
                    return

                total = len(profiles)
                connected = False
                winning_profile = ""

                for idx, profile in enumerate(profiles, start=1):
                    if is_closing or SERVICE_RUN_ID != my_run_id:
                        return
                    profile_name = str(profile.get("name", f"warp-{idx}") or f"warp-{idx}")
                    if total > 1:
                        self.log_func(f"[RU] [Diag] WARP bootstrap стратегия {idx}/{total}: {profile_name}.")
                    else:
                        self.log_func(f"[RU] [Diag] WARP bootstrap стратегия: {profile_name}.")

                    if not self._start_warp_bootstrap_process(profile):
                        self.log_func(f"[RU] [Diag] Не удалось запустить bootstrap winws для профиля {profile_name}.")
                        continue

                    try:
                        connected = self._run_bootstrap_connection_cycle(my_run_id, bootstrap_profile=profile)
                    finally:
                        self._stop_warp_bootstrap_process()

                    if connected:
                        winning_profile = profile_name
                        self._remember_successful_warp_bootstrap(profile_name)
                        self.log_func(f"[RU] [Diag] WARP bootstrap сработал: {profile_name}.")
                        break

                    try:
                        self.run_warp_cli("disconnect", timeout=8)
                    except:
                        pass
                    time.sleep(0.6)

                if connected:
                    return

                self.mark_bootstrap(False)
                if total > 1:
                    self.log_func("[RU] [Warning] Все bootstrap стратегии WARP исчерпаны.")
                elif not winning_profile:
                    self.log_func("[RU] [Warning] Bootstrap стратегия WARP не сработала.")

            except Exception as e:
                self.log_func(f"[RU] КРИТИЧЕСКАЯ ОШИБКА WARP: {e}")
                import traceback
                if IS_DEBUG_MODE:
                    traceback.print_exc()

            finally:
                self._stop_warp_bootstrap_process()
                if not self.bootstrap_event.is_set():
                    self.mark_bootstrap(False)
                self._is_starting_now = False

        def _wait_for_service_stopped(self, service_name=None, timeout=8.0):
            svc_name = str(service_name or self.SERVICE_NAME or "").strip()
            if not svc_name:
                return True
            deadline = time.time() + max(1.0, float(timeout))
            while time.time() < deadline:
                rc, out, err = self._run_sc("query", svc_name, timeout=6)
                query_text = f"{out}\n{err}".upper()
                if rc != 0 and any(marker in query_text for marker in ["1060", "DOES NOT EXIST", "НЕ СУЩЕСТВУЕТ"]):
                    return True
                if "STOPPED" in query_text or "1062" in query_text or "NOT STARTED" in query_text:
                    return True
                time.sleep(0.25)
            return False

        def _stop_warp_runtime(self, force_kill=True):
            try:
                self._set_service_proxy_environment(enable_proxy=False)
            except:
                pass

            try:
                self.run_warp_cli("disconnect", timeout=6)
            except:
                pass

            try:
                self._run_sc("stop", self.SERVICE_NAME, timeout=12)
            except:
                pass

            stopped = self._wait_for_service_stopped(self.SERVICE_NAME, timeout=8.0)

            if force_kill or not stopped:
                for proc_name in self._warp_process_names():
                    try:
                        subprocess.run(
                            ["taskkill", "/F", "/IM", proc_name, "/T"],
                            capture_output=True,
                            creationflags=subprocess.CREATE_NO_WINDOW,
                        )
                    except:
                        pass
                try:
                    self._run_sc("stop", self.SERVICE_NAME, timeout=8)
                except:
                    pass
                self._wait_for_service_stopped(self.SERVICE_NAME, timeout=6.0)

            self.is_connected = False

        def stop_service(self):
            """Stop WARP service and clean up."""
            try:
                self._stop_awg_proxy_process(reset_backend=True, force_orphans=True)
                self._stop_warp_bootstrap_process()
                self._stop_warp_runtime(force_kill=True)
            except:
                pass

        def is_port_open(self, port):
            import socket
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(1)
                result = sock.connect_ex(('127.0.0.1', port))
                sock.close()
                return result == 0
            except: return False

        def _test_socks5_internet(self, port, timeout=2.0):
            if getattr(self, "active_backend", "") == "awg":
                return bool(self._test_awg_backend_ready(port=port, timeout=max(4.0, float(timeout) + 2.0)))
            import socket, struct
            try:
                with socket.create_connection(('127.0.0.1', port), timeout=timeout) as s:
                    s.sendall(b'\x05\x01\x00')
                    if s.recv(2) != b'\x05\x00': return False
                    s.sendall(b'\x05\x01\x00\x01' + socket.inet_aton('1.1.1.1') + struct.pack('!H', 80))
                    res = s.recv(10)
                    return len(res) >= 2 and res[1] == 0
            except: return False

        def wait_for_connection(self, timeout=20):
            import time
            start_time = time.time()
            port_open_streak = 0
            proxy_repair_attempts = 0
            last_proxy_repair_ts = 0.0
            alt_ports_checked = False
            while time.time() - start_time < timeout:
                # Primary success signal: local SOCKS proxy is listening.
                port_open = self.is_port_open(self.port)
                if port_open:
                    port_open_streak += 1
                else:
                    port_open_streak = 0

                # Try extracting tunnel details even when `status` is flaky (IPC timeout).
                if port_open:
                    details = ""
                    stats_res = self.run_warp_cli("tunnel", "stats", timeout=8)
                    if stats_res and stats_res.returncode == 0:
                        stats_out = self.decode_output(stats_res.stdout)
                        import re

                        # Current CLI uses "Tunnel Protocol:", older builds had "Protocol:".
                        proto_match = re.search(r"(?:Tunnel\s+)?Protocol:\s*(.+)", stats_out, re.IGNORECASE)
                        proto_str = proto_match.group(1).strip() if proto_match else "Unknown"

                        # Current CLI uses "Endpoints: <ip>, ...".
                        ip_match = re.search(r"Endpoints:\s*([^\s,]+)", stats_out, re.IGNORECASE)
                        ip_str = ip_match.group(1).strip() if ip_match else "Unknown"

                        masked_ip = ip_str
                        conn_type = "Unknown"

                        if "." in ip_str and ":" not in ip_str:
                            conn_type = "IPv4"
                            parts = ip_str.split(".")
                            if len(parts) == 4:
                                masked_ip = f"***.***.{parts[2]}.{parts[3]}"
                        elif ":" in ip_str:
                            conn_type = "IPv6"
                            masked_ip = "IPv6:***"

                        details = f" {masked_ip} {proto_str} ({conn_type})"
                        
                        if not self._test_socks5_internet(self.port):
                            if port_open_streak % 5 == 1:
                                self.log_func(f"[RU] [Diag] {self.port} подключен {masked_ip}, но нет трафика. Ожидание...")
                            continue

                        self.log_func(f"[RU] {self.port} готов{details}{self._bootstrap_1371_suffix()}")
                        self.is_connected = True
                        return True

                    # If stats API is temporarily unavailable but SOCKS is stable, accept as connected.
                    if port_open_streak >= 2:
                        if not self._test_socks5_internet(self.port):
                            continue
                        self.log_func(f"[RU] {self.port} готов{self._bootstrap_1371_suffix()}")
                        self.is_connected = True
                        return True

                status = self.get_status()
                status_low = (status or "").lower()
                if "connected" in status_low:
                    now_ts = time.time()
                    elapsed = now_ts - start_time
                    if (
                        not port_open
                        and elapsed >= 5
                        and proxy_repair_attempts < 2
                        and (now_ts - last_proxy_repair_ts) >= 4
                    ):
                        proxy_repair_attempts += 1
                        last_proxy_repair_ts = now_ts
                        self.log_func(
                            f"[RU] [Diag] Статус Connected, но порт {self.port} закрыт. Повторяем mode proxy/port ({proxy_repair_attempts}/2)..."
                        )
                        self.set_proxy_port(self.port)
                        self.set_proxy_mode()
                    if (
                        not port_open
                        and elapsed >= 10
                        and proxy_repair_attempts >= 2
                        and not alt_ports_checked
                    ):
                        alt_ports_checked = True
                        self.log_func("[RU] [Diag] Базовый порт недоступен. Пытаемся подобрать резервный SOCKS порт...")
                        try:
                            if self._try_alternate_proxy_ports():
                                # Re-check immediately after switching port.
                                if self.is_port_open(self.port):
                                    self.log_func(f"[RU] [Diag] Резервный порт {self.port} активен.")
                                    continue
                        except Exception as e:
                            if IS_DEBUG_MODE:
                                self.log_func(f"[RU] [Diag] Ошибка подбора резервного порта: {e}")
                    if IS_DEBUG_MODE:
                        self.log_func(f"[RU] Статус Connected, порт {self.port} пока закрыт...")
                elif "ipc call hit a timeout" in status_low or "error communicating with daemon" in status_low:
                    if IS_DEBUG_MODE:
                        self.log_func("[RU] [Diag] status IPC timeout (ожидание, tunnel может уже подниматься)...")
                else:
                    if IS_DEBUG_MODE:
                        self.log_func(f"[RU] Статус: {status}...")
                time.sleep(1)

            final_status = self.get_status()
            self.log_func(f"[RU] [Warning] WARP не перешел в рабочий режим за {timeout} сек. Статус: {final_status}. Порт {self.port} закрыт.")
            return False
        
        def stop(self):
            """Disconnect from WARP but keep the service running for faster restart."""
            # Do not keep CloudflareWARP service pinned to local proxy when Nova is stopped.
            try:
                self._set_service_proxy_environment(enable_proxy=False)
            except:
                pass

            if is_closing:
                # When closing the app, disconnect and fully stop services to release bin/ folder locks
                try:
                    self.stop_service()
                except:
                    pass
                return

            if getattr(self, "active_backend", "") == "awg":
                self.log_func("[RU] Отключение AWG...")
                self._stop_awg_proxy_process(reset_backend=True, force_orphans=True)
                self.is_connected = False
                return

            self.log_func("[RU] Отключение...")
            self.run_warp_cli("disconnect")
            self.is_connected = False


    class PacManager:
        def __init__(self, log_func=None):
            self.log_func = log_func or print
            self.pac_file = os.path.join(get_base_dir(), "temp", "nova.pac")
            self.server_port = 1369
            self.server_thread = None
            self.httpd = None
            self.warp_port = int(globals().get("WARP_PORT", 1370))
            self.registry_backup = {}
            self._last_route_signature = None
            self._last_eu_route_state = None
            self._last_proxy_diag_state = None
            self._winhttp_backup_dump = None
            self._winhttp_proxy_applied = False
            # WinHTTP override can break some desktop apps; keep opt-in.
            try:
                self._sync_winhttp_proxy = str(os.environ.get("NOVA_SYNC_WINHTTP_PROXY", "0")).strip().lower() in ("1", "true", "yes", "on")
            except:
                self._sync_winhttp_proxy = False
            # Safety cleanup: if an older run left WinHTTP on Nova local proxy,
            # clear it when sync mode is disabled to avoid breaking local agents.
            try:
                if not self._sync_winhttp_proxy:
                    self._clear_stale_nova_winhttp_proxy()
            except:
                pass

        def _load_domain_list(self, filepath):
            """Load domains from a text file."""
            domains = set()
            if os.path.exists(filepath):
                with open(filepath, "r", encoding="utf-8") as f:
                    for line in f:
                        # Clean up potentially corrupted text (e.g. UTF-16 saved as UTF-8)
                        line = line.replace('\x00', '')
                        d = line.split('#')[0].strip().lower()
                        d = ''.join(d.split()) # Remove any internal spaces
                        if not d:
                            continue
                        # Normalize common user input formats: URL, wildcard, path.
                        d = d.replace("\\", "/")
                        if "://" in d:
                            d = d.split("://", 1)[1]
                        d = d.split("/", 1)[0]
                        d = d.split(":", 1)[0]
                        if d.startswith("*."):
                            d = d[2:]
                        d = d.strip(".")
                        if d and "." in d:
                            domains.add(d)
            return domains

        def _run_netsh(self, args, timeout=8):
            try:
                result = subprocess.run(
                    ["netsh"] + list(args),
                    capture_output=True,
                    timeout=timeout,
                    creationflags=subprocess.CREATE_NO_WINDOW
                )
                out = (result.stdout or b"").decode("utf-8", errors="ignore")
                err = (result.stderr or b"").decode("utf-8", errors="ignore")
                return result.returncode, out, err
            except Exception as e:
                return -1, "", str(e)

        def _ensure_winhttp_backup(self):
            if self._winhttp_backup_dump is not None:
                return
            rc, out, err = self._run_netsh(["winhttp", "dump"], timeout=8)
            if rc == 0 and out.strip():
                self._winhttp_backup_dump = out
            else:
                self._winhttp_backup_dump = "pushd winhttp\r\nreset proxy\r\npopd\r\n"
                if IS_DEBUG_MODE:
                    self.log_func(f"[System] [Diag] Не удалось снять backup WinHTTP dump: {err or out or rc}")

        def _apply_winhttp_proxy(self):
            """Route WinHTTP/CLI clients via 1371 while Nova is active."""
            try:
                self._ensure_winhttp_backup()
                rc, out, err = self._run_netsh(
                    [
                        "winhttp", "set", "proxy",
                        "proxy-server=127.0.0.1:1371",
                        "bypass-list=localhost;127.0.0.1;::1;<local>"
                    ],
                    timeout=8
                )
                if rc == 0:
                    self._winhttp_proxy_applied = True
                    if IS_DEBUG_MODE:
                        self.log_func("[System] WinHTTP прокси направлен на 127.0.0.1:1371.")
                elif IS_DEBUG_MODE:
                    self.log_func(f"[System] [Diag] WinHTTP set proxy failed: {err or out or rc}")
            except Exception as e:
                if IS_DEBUG_MODE:
                    self.log_func(f"[System] [Diag] Ошибка применения WinHTTP proxy: {e}")

        def _restore_winhttp_proxy(self):
            """Restore original WinHTTP proxy settings from backup dump."""
            if not self._winhttp_proxy_applied:
                return
            try:
                self._ensure_winhttp_backup()
                restore_file = os.path.join(get_base_dir(), "temp", "winhttp_restore.txt")
                with open(restore_file, "w", encoding="utf-8", newline="\r\n") as f:
                    f.write(self._winhttp_backup_dump or "pushd winhttp\r\nreset proxy\r\npopd\r\n")
                rc, out, err = self._run_netsh(["-f", restore_file], timeout=10)
                if rc == 0:
                    if IS_DEBUG_MODE:
                        self.log_func("[System] WinHTTP прокси восстановлен.")
                elif IS_DEBUG_MODE:
                    self.log_func(f"[System] [Diag] WinHTTP restore failed: {err or out or rc}")
            except Exception as e:
                if IS_DEBUG_MODE:
                    self.log_func(f"[System] [Diag] Ошибка восстановления WinHTTP proxy: {e}")
            finally:
                self._winhttp_proxy_applied = False

        def _clear_stale_nova_winhttp_proxy(self):
            """Reset stale WinHTTP proxy if it still points to Nova local endpoint."""
            try:
                rc, out, err = self._run_netsh(["winhttp", "show", "proxy"], timeout=8)
                if rc != 0:
                    return
                txt = (out or "").lower()
                # Touch only known Nova local endpoint; do not reset arbitrary user local proxies.
                if "127.0.0.1:1371" not in txt:
                    return
                rc2, out2, err2 = self._run_netsh(["winhttp", "reset", "proxy"], timeout=8)
                if IS_DEBUG_MODE and rc2 == 0:
                    self.log_func("[System] [Diag] Обнаружен и сброшен залипший WinHTTP proxy 127.0.0.1:1371.")
                elif IS_DEBUG_MODE and rc2 != 0:
                    self.log_func(f"[System] [Diag] Не удалось сбросить залипший WinHTTP proxy: {err2 or out2 or rc2}")
            except:
                pass

        def _parse_ip_list_entries(self, entries):
            """Parse IP/CIDR strings into [ip, mask/prefix, version] records for PAC."""
            import ipaddress
            res = []
            for entry in entries or []:
                line = str(entry or "").split('#')[0].strip()
                if not line:
                    continue
                try:
                    # If just IP, default to /32 or /128.
                    if '/' not in line:
                        if ':' in line:
                            line += '/128'
                        else:
                            line += '/32'

                    net = ipaddress.ip_network(line, strict=False)

                    if net.version == 4:
                        # IPv4: [IP, Mask, 4] for isInNet.
                        res.append([str(net.network_address), str(net.netmask), 4])
                    elif net.version == 6:
                        # IPv6: [IP, PrefixLen, 6] for isInNetEx.
                        res.append([str(net.network_address), str(net.prefixlen), 6])
                except:
                    pass
            return res

        def _load_ip_list(self, filepath):
            """Load IPs/CIDR from file and return list of [ip, mask/prefix, version] for PAC."""
            lines = []
            if os.path.exists(filepath):
                with open(filepath, "r", encoding="utf-8") as f:
                    for line in f:
                        lines.append(line)
            return self._parse_ip_list_entries(lines)

        def is_port_open(self, port):
            import socket
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.settimeout(0.5)
                return s.connect_ex(('127.0.0.1', port)) == 0

        def _is_http_proxy_alive(self, port, timeout=1.5):
            """Verify local HTTP proxy is really usable for CONNECT tunnels."""
            return is_local_http_proxy_tunnel_ready(port=port, timeout=timeout)

        def generate_pac(self, warp_override=None, opera_override=None):
            """Generates PAC file with smart failover logic.
            
            Args:
                warp_override: If not None, use this bool for warp_active instead of re-checking.
                opera_override: If not None, use this bool for opera_active instead of re-checking.
            """
            try:
                base = get_base_dir()
                user_ru_domains = self._load_domain_list(os.path.join(base, "list", "u_ru.txt"))
                user_eu_domains = self._load_domain_list(os.path.join(base, "list", "u_eu.txt"))
                ru_domains = self._load_domain_list(os.path.join(base, "list", "ru.txt"))
                eu_domains = self._load_domain_list(os.path.join(base, "list", "eu.txt"))
                exclude_domains = self._load_domain_list(os.path.join(base, "list", "exclude.txt"))
                discord_domains = get_discord_runtime_domains()
                telegram_domains = get_telegram_runtime_domains()
                whatsapp_domains = self._load_domain_list(os.path.join(base, "list", "whatsapp.txt"))
                user_ru_ips = self._load_ip_list(os.path.join(base, "ip", "u_ru.txt"))
                user_eu_ips = self._load_ip_list(os.path.join(base, "ip", "u_eu.txt"))
                ru_ips = self._load_ip_list(os.path.join(base, "ip", "ru.txt"))
                eu_ips = self._load_ip_list(os.path.join(base, "ip", "eu.txt"))
