                user_ru_js = "{" + ",".join(f'"{d}":1' for d in user_ru_domains) + "}"
                user_eu_js = "{" + ",".join(f'"{d}":1' for d in user_eu_domains) + "}"
                ru_js = "{" + ",".join(f'"{d}":1' for d in ru_domains) + "}"
                eu_js = "{" + ",".join(f'"{d}":1' for d in eu_domains) + "}"
