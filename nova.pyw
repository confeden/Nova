                                            # \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u0444\u0438\u043b\u044c\u0442\u0440\u0430\u0446\u0438\u0438
                                            filtered_out = len(s_spec_list) - len(unique_spec)
