                        continue
                    if isinstance(_v, dict):
                        _v = _v.get("args", [])
                    if not isinstance(_v, list):
                        continue
                    for _item in _v:
                        if not isinstance(_item, str):
                            continue
                        _text = _item.strip().lower()
