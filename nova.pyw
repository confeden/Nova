    def is_local_port_open_quick(port, timeout=0.25):
        try:
            import socket
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.settimeout(timeout)
                return s.connect_ex(("127.0.0.1", int(port))) == 0
        except:
            return False

