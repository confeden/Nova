    def _split_strategy_segments_portable(arg_list):
        segments = []
        current_seg = []
        for arg in arg_list or []:
            if arg == "--new":
                if current_seg:
                    segments.append(current_seg)
                    current_seg = []
                continue
            current_seg.append(arg)
        if current_seg:
            segments.append(current_seg)
        return segments

